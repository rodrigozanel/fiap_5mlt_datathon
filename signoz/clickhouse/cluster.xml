<?xml version="1.0"?>
<clickhouse>
    <!-- ZooKeeper configuration for SigNoz -->
    <zookeeper>
        <node index="1">
            <host>signoz-zookeeper</host>
            <port>2181</port>
        </node>
    </zookeeper>

    <!-- Configuration of clusters that could be used in Distributed tables -->
    <remote_servers>
        <cluster>
            <shard>
                <replica>
                    <host>signoz-clickhouse</host>
                    <port>9000</port>
                </replica>
            </shard>
        </cluster>
    </remote_servers>
</clickhouse>
